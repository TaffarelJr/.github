#-------------------------------------------------------------------------------
# EditorConfig: https://EditorConfig.org
# Remove the line below if you want to inherit .editorconfig settings from higher directories
#-------------------------------------------------------------------------------
root = true

#-------------------------------------------------------------------------------
# Primary Settings
#-------------------------------------------------------------------------------

[*]
charset = utf-8
indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 120
trim_trailing_whitespace = true
insert_final_newline = true

#-------------------------------------------------------------------------------
# Spacing Exceptions
#-------------------------------------------------------------------------------

[*.{md,yaml,yml}]
indent_size = 2
tab_width = 2
